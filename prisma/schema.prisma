// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
}

enum SessionStatus {
  OPEN
  SUBMITTED
  ARCHIVED
}

enum CommentStatus {
  OPEN
  RESOLVED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  role         Role          @default(ADMIN)
  notifyEmail  String?
  projects     Project[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Project {
  id              String         @id @default(cuid())
  name            String
  defaultTargetUrl String?
  ownerId          String
  owner            User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sessions        ReviewSession[]
  pages           Page[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([ownerId])
}

model ReviewSession {
  id           String        @id @default(cuid())
  token        String        @unique @default(cuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerName String?
  status       SessionStatus @default(OPEN)
  comments     Comment[]
  digests      DigestLog[]
  createdAt    DateTime      @default(now())
  submittedAt  DateTime?
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
}

model Page {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url               String
  title             String?
  lastProxyFetchAt  DateTime?
  comments          Comment[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, url])
  @@index([projectId])
}

model Comment {
  id             String        @id @default(cuid())
  sessionId      String
  session        ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pageId         String
  page           Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  authorName     String?
  text           String
  xpath          String
  viewportWidth  Int
  viewportHeight Int
  scrollX        Int           @default(0)
  scrollY        Int           @default(0)
  screenshotData String?
  status         CommentStatus @default(OPEN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([sessionId])
  @@index([pageId])
}

model DigestLog {
  id             String        @id @default(cuid())
  sessionId      String
  session        ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recipientEmail String
  payloadJson    String
  sentAt         DateTime      @default(now())

  @@index([sessionId])
}
