# Copy to .env (read by Prisma CLI) and/or .env.local (Next.js, overrides .env).
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Track A — local Postgres via Docker (docker compose up -d db):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/basedb?schema=public"
#
# Track B — Supabase (or any managed Postgres):
#   Settings -> Database -> Connection string.
#   - Migrations: use the DIRECT connection (port 5432).
#   - Runtime (serverless/edge): the pooler is fine (port 6543, ?pgbouncer=true).
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"
